# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class

# Build and packaging artifacts
build/
dist/
.eggs/
*.egg-info/
pip-wheel-metadata/

# Virtual environments
.venv/
venv/
env/

# Test and tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# Local editor/system files
.DS_Store
.idea/
.vscode/

# Local lockfiles/logs generated during ad-hoc runs
uv.lock
*.log
*.pt

!src/auvrl/tasks/
!src/auvrl/tasks/**
!tests/tasks/
!tests/tasks/**
src/auvrl/tasks/**/__pycache__/
src/auvrl/tasks/**/*.py[cod]
tests/tasks/**/__pycache__/
tests/tasks/**/*.py[cod]
